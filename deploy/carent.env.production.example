NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# Replace before first deploy.
AUTH_SECRET=change-this-to-a-long-random-secret

# PostgreSQL connection string.
DATABASE_URL=postgres://carrent:replace-me@carent-postgres:5432/carrent

# Upload directory inside the app container.
CARENT_UPLOAD_DIR=/data/uploads

# Optional: pin a stable key if you ever run multiple instances.
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
